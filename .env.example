# =============================================================================
# Semi Senti - Environment Variables Template (PRD v1.2)
# -----------------------------------------------------------------------------
# 실제 사용 시 본 파일을 ".env" 로 복사한 뒤 값을 채워 사용하세요.
# 절대로 실키(.env)는 깃에 커밋하지 마세요.
# =============================================================================

# ----- 실행 환경 -------------------------------------------------------------
SEMI_SENTI_ENV=local                  # local | dev | prod
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR

# ----- PostgreSQL 데이터베이스 (PRD §4.2) ------------------------------------
# 형식: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://semisenti:semisenti@localhost:5432/semisenti
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10

# ----- 캐시 TTL (F-1.3.2) ----------------------------------------------------
NEWS_CACHE_TTL_MINUTES=30
FINANCIAL_CACHE_TTL_HOURS=24
PRICE_CACHE_TTL_MINUTES=15
PRICE_POLL_INTERVAL_SECONDS=60        # LiveDataPipeline 주가 폴링 간격(초)
LIVE_DATA_ENABLED=true                # FastAPI 기동 시 자동 수집 활성화

# ----- FastAPI 서버 ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001

# ----- 외부 API 키 -----------------------------------------------------------
# Open DART (https://opendart.fss.or.kr/)
OPEN_DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_DEFAULT_REPRT_CODE=11011        # 11011=사업보고서, 11012=반기

# 네이버 개발자 센터 (https://developers.naver.com/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_NEWS_DISPLAY=20
NAVER_NEWS_SORT=date

# HTTP 공통 옵션
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3

# ----- pykrx (F-1.1.2) -------------------------------------------------------
PYKRX_DATE_FROM=20140101             # 주가 수집 시작일 (YYYYMMDD)

# ----- Gemini API (F-3.3) -----------------------------------------------------
# 발급: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=5

# ----- 텔레그램 봇 (F-5.1) --------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_MAX_RETRIES=3
NOTIFY_BACKOFF_SECONDS=1.0
SENTIMENT_SHIFT_THRESHOLD_PT=30.0

# ----- 업황 사이클 (F-2.4) --------------------------------------------------
CYCLE_INVENTORY_TARGET=4.0
CYCLE_INVENTORY_SPAN=2.0
CYCLE_REVENUE_TARGET=0.0
CYCLE_REVENUE_SPAN=20.0
CYCLE_MARGIN_TARGET=10.0
CYCLE_MARGIN_SPAN=15.0

# ----- KoNLPy / JVM ----------------------------------------------------------
KONLPY_JVM_MAX_HEAP_MB=1024
KONLPY_TAGGER=Okt

# ----- 분석 엔진 파라미터 (F-3.2) -------------------------------------------
SENTIMENT_NORMALIZATION_K=30
SENTIMENT_TOP_KEYWORD_LIMIT=5

BAND_LOOKBACK_DAYS=90
BAND_MARGIN=0.15

# 다중 관점 시그널 임계값 (PRD §F-3.2)
SIGNAL_SHORT_BUY_THRESHOLD=25
SIGNAL_SHORT_SELL_THRESHOLD=-25
SIGNAL_MID_BUY_THRESHOLD=25
SIGNAL_MID_SELL_THRESHOLD=-25
SIGNAL_LONG_BUY_THRESHOLD=25
SIGNAL_LONG_SELL_THRESHOLD=-25

# 다이버전스 (F-2.3)
DIVERGENCE_WINDOW_DAYS=5
DIVERGENCE_PRICE_THRESHOLD=2.0
DIVERGENCE_SENTIMENT_THRESHOLD=10.0
