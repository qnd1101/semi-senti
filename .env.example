# =============================================================================
# Semi Senti - Environment Variables Template
# -----------------------------------------------------------------------------
# 실제 사용 시 본 파일을 ".env" 로 복사한 뒤 값을 채워 사용하세요.
# 절대로 실키(.env)는 깃에 커밋하지 마세요. (사용자 룰: 하드코딩 금지)
# =============================================================================

# ----- 실행 환경 -------------------------------------------------------------
SEMI_SENTI_ENV=local                  # local | dev | prod
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR

# ----- SQLite 데이터베이스 ---------------------------------------------------
# 프로젝트 루트 기준 상대경로 또는 절대경로 모두 허용.
# (Phase 1-1 통합 테스트 스크립트가 기대하는 위치와 동일하게 ./db/semisenti.db 사용)
SEMI_SENTI_SQLITE_PATH=./db/semisenti.db
SEMI_SENTI_SQLITE_TIMEOUT=10          # 초 단위 (sqlite3.connect timeout)

# ----- 캐시 TTL (F-1.3.2) ----------------------------------------------------
NEWS_CACHE_TTL_MINUTES=30             # 뉴스 캐시 유효 시간
FINANCIAL_CACHE_TTL_HOURS=24          # 재무 데이터 캐시 유효 시간
PRICE_CACHE_TTL_MINUTES=15            # 주가 캐시 유효 시간

# ----- 외부 API 키 -----------------------------------------------------------
# Open DART (https://opendart.fss.or.kr/)
OPEN_DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_DEFAULT_REPRT_CODE=11011        # 11011=사업보고서, 11012=반기, 11013=1분기, 11014=3분기

# 네이버 개발자 센터 (https://developers.naver.com/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_NEWS_BASE_URL=https://openapi.naver.com/v1/search/news.json
NAVER_NEWS_DISPLAY=20                # 1~100
NAVER_NEWS_SORT=date                 # date | sim

# HTTP 공통 옵션 (외부 API 호출 시 timeout/retry)
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3

# yfinance
YFINANCE_DEFAULT_PERIOD=1mo          # 1d | 5d | 1mo | 3mo | 6mo | 1y | 2y | 5y | max
YFINANCE_DEFAULT_INTERVAL=1d         # 1m | 5m | 1h | 1d | 1wk | 1mo

# 텔레그램 봇 (Phase 4-1, T-040)
# 발급 절차:
#   1) 텔레그램에서 @BotFather 검색 → /newbot 으로 봇 생성
#   2) 발급된 토큰을 TELEGRAM_BOT_TOKEN 에 입력
#   3) 봇과 1:1 대화 시작 → @userinfobot 등으로 chat_id 확인
#   4) TELEGRAM_CHAT_ID 에 chat_id 입력 (예: 123456789, 그룹은 음수)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 알림 발송 옵션 (T-041, T-043)
NOTIFY_MAX_RETRIES=3                  # 텔레그램 재시도 횟수 상한 (UC-05 §E1)
NOTIFY_BACKOFF_SECONDS=1.0            # 재시도 간 대기(초). 선형 backoff.

# 감성 급변 경고 (T-042)
SENTIMENT_SHIFT_THRESHOLD_PT=30.0     # |Δsentiment| 가 이 값 이상이면 경고

# 업황 사이클 (T-044, T-045)
CYCLE_INVENTORY_TARGET=4.0            # 재고자산 회전율 기준점 (회/연)
CYCLE_INVENTORY_SPAN=2.0              # 정규화 폭 (±span 으로 -1~+1 매핑)
CYCLE_REVENUE_TARGET=0.0              # YoY 매출 성장률 기준 (%)
CYCLE_REVENUE_SPAN=20.0
CYCLE_MARGIN_TARGET=10.0              # 영업이익률 기준 (%)
CYCLE_MARGIN_SPAN=15.0

# ----- KoNLPy / JVM (PRD §4.2) ----------------------------------------------
# JVM 힙 메모리 (MB). 8GB RAM 환경에서 안전한 기본값.
KONLPY_JVM_MAX_HEAP_MB=1024
KONLPY_TAGGER=Okt                    # Okt | Hannanum | Komoran | Kkma

# ----- 분석 엔진 파라미터 (Phase 2) ------------------------------------------
# Sentiment normalization (T-019): score = 100 * tanh(raw / k)
SENTIMENT_NORMALIZATION_K=10
SENTIMENT_TOP_KEYWORD_LIMIT=5

# Fundamental band (T-023)
BAND_LOOKBACK_DAYS=90                # 밴드 산출 시 활용할 과거 일수
BAND_MARGIN=0.15                     # band_low/high = mid * (1 ∓ margin)

# Signal threshold (T-024, PRD §F-3.2)
SIGNAL_SENTIMENT_BUY_THRESHOLD=-70
SIGNAL_SENTIMENT_SELL_THRESHOLD=70

# Divergence (T-026, T-027)
DIVERGENCE_WINDOW_DAYS=5             # N일 이동 추세 비교
DIVERGENCE_PRICE_THRESHOLD=2.0       # 주가 변동 % 임계값 (절대값)
DIVERGENCE_SENTIMENT_THRESHOLD=10.0  # 감성 변화 pt 임계값 (절대값)
