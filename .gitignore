# =============================================================================
# Semi Senti — Git ignore (public repo 준비)
# =============================================================================

# ----- Secrets & environment -------------------------------------------------
.env
.env.*
!.env.example
!**/.env.example
!**/.env.local.example
*.pem
*.key
secrets/
credentials.json
*credentials*.json

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python build artifact directory at repo root only (avoid eating web/lib/).
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ----- Virtual environments --------------------------------------------------
.venv/
venv/
ENV/
env/
.python-version

# ----- Testing & coverage ----------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
pytestdebug.log

# ----- Type checkers & linters -----------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ----- Jupyter / notebooks (outputs only) ------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- Streamlit -------------------------------------------------------------
.streamlit/secrets.toml

# ----- IDE & editors ---------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ----- OS --------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----- Project data (local SQLite) -------------------------------------------
db/*.db
db/cache/
db/*.sqlite
db/*.sqlite3
db/*.db-journal
db/*.sqlite-journal
!db/.gitkeep

# ----- Documentation (local PDF originals) -----------------------------------
docs/**/*.pdf
docs/*.pdf

# ----- Private notes (not tracked) -------------------------------------------
docs/TODO-private.md
*-private.md
notes/

# ----- Logs & local caches ---------------------------------------------------
*.log
logs/
.cache/
.pytest_cache/

# ----- Packaging / install artifacts -----------------------------------------
*.manifest
*.spec
 